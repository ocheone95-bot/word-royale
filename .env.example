# Word Royale — env template.
# Скопируй этот файл в .env и заполни значениями. .env в git не коммитим.

# --- Supabase ---
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx          # ТОЛЬКО на backend, никогда не в frontend

# --- Telegram ---
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_BOT_USERNAME=word_royale_bot
WEBAPP_URL=https://word-royale.vercel.app

# --- Bot (apps/bot, отдельный Vercel project) ---
# Эти переменные ставятся в Vercel-проект бота, не в miniapp.
MINI_APP_URL=https://word-royale-miniapp.vercel.app/
TELEGRAM_WEBHOOK_SECRET=long-random-string   # сверяется с заголовком от Telegram
SUPABASE_URL=https://xxx.supabase.co         # без VITE_, для server-side клиента

# --- Аналитика ---
VITE_POSTHOG_KEY=xxx
VITE_POSTHOG_HOST=https://app.posthog.com

# --- Sentry ---
VITE_SENTRY_DSN=xxx

# --- Monetag (rewarded ads, после регистрации) ---
VITE_MONETAG_ZONE_ID=xxx
