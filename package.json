{
  "name": "word-royale",
  "version": "0.0.0",
  "private": true,
  "description": "Word Royale — Telegram Mini App. Casual word puzzle with daily challenge and global leaderboard.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "seed:dictionary": "node --env-file=.env.local packages/dictionary/scripts/seed-db.mjs",
    "test": "vitest run",
    "build:bot-avatar": "node scripts/generate-bot-avatar.mjs"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "supabase": "^2.95.4",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@telegram-apps/transformers": {
      "valibot": "^1.3.1"
    },
    "@telegram-apps/bridge": {
      "valibot": "^1.3.1"
    },
    "valibot": "^1.3.1"
  }
}
